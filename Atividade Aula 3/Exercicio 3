# O "else" na linguagem R tem uma finalidade de executar um bloco de código quando a condição do "if" é falsa, ou seja, "if" tem por finalidade testar uma condição e "else" entra em ação quando essa condição não é atendida

# Propor o else para o script abaixo:

# for (pkg in required_packages) { if (!require(pkg, character.only = TRUE)) { install.packages(pkg, dependencies = TRUE) library(pkg, character.only = TRUE) } }

# Proposta: 
required_packages <- c("ggplot2", "dplyr", "readr") # é necessário criar uma variável contendo os pacotes de interesse

for (pkg in required_packages) {
  if (!requireNamespace(pkg, quietly = TRUE)) {
    message("Instalando pacote: ", pkg)
    install.packages(pkg, dependencies = TRUE)
  } else {
    message("Pacote já instalado: ", pkg)
  }
  
  library(pkg, character.only = TRUE)
}

